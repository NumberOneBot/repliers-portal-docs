{
  "name": "docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "postbuild": "pagefind --site .next/server/app --output-path public/_pagefind",
    "start": "next start -p 4000",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "prettier": "prettier --check ./**/*.{ts,tsx,js,mdx}",
    "prettier:fix": "prettier --write ./**/*.{ts,tsx,js,mdx}"
  },
  "dependencies": {
    "next": "16.2.10",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "pagefind": "^1.3.0",
    "prettier": "^3.7.4",
    "typescript": "^5.0.0"
  }
}
